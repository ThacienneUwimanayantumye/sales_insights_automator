# Environment & secrets
.env
.env.*           # catches .env.example.env and any other misnamed env files
!.env.example    # but keep the example template

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Virtual environment
.venv/
venv/
env/

# Test cache
.pytest_cache/
.coverage
htmlcov/

# Generated / downloaded data (not source code)
data/raw/
data/audit/
*.db

# Generated schema files (created by setup_schema.py at runtime)
sales_insights_automator/config/*_schema.json

# macOS
.DS_Store
.AppleDouble

# IDE
.idea/
.vscode/
*.swp
