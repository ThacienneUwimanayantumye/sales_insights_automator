# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1024

# ── Google Drive (when connector is implemented) ──────────────────────────────
GDRIVE_CREDENTIALS_PATH=config/google_credentials.json

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
