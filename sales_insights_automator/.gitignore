# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Environment variables (never commit secrets) ──────────────────────────────
.env
# Keep the example template
!.env.example

# ── Test / lint caches ────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# ── Runtime-generated outputs (re-created by the app on each run) ─────────────
data/raw/*.json
data/audit/
# Sample SQLite DB can be regenerated by scripts/create_sample_data.py
data/samples/*.db

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── Editor ────────────────────────────────────────────────────────────────────
*.swp
*.swo
.idea/
.vscode/
